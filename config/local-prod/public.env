# Local-prod non-secret config (from config/local-prod.env)
# This overlay is for running locally against the prod swarm (swarm1)

# Shared non-secret config (from config/config.env)
USERID=1000
ADMIN_EMAILS=["eric.busboom@jointheleague.org", "admin@jointheleague.org", "it@jointheleague.org"]
INSTRUCTOR_EMAIL_REXEX=^[^@]+@jointheleague\.org$
STUDENT_EMAIL_REGEX=^[^@]+@students\.jointheleague\.org$
CODESERVER_PORT=80

# noVNC client URL path, appended after https://{host}/ for the desktop view.
# NEW: direct Caddy /websockify route + auto-reconnect (fixes intermittent drops).
VNC_URL_PATH='vnc/vnc.html?autoconnect=true&reconnect=true&reconnect_delay=1000&resize=scale&path=websockify'
# OLD: code-server /proxy/6080 hop, no reconnect — swap in to roll back.
#VNC_URL_PATH='proxy/6080/vnc_lite.html?path=proxy/6080/websockify&scale=true'

SWARM_NODE_LABEL=code-host-user
SSH_WAIT_TIMEOUT=900
DO_CLOUD_INIT=swarm-node-init-v2.yaml
ID_RSA_FILE=id_rsa

DEVEL=
PRODUCTION=1
OAUTHLIB_INSECURE_TRANSPORT=1

# Dev-only: show a "Log in as admin" button that bypasses OAuth and logs
# in as root. Enabled so a remote operator running `just dev-pl` can log in.
DEV_ADMIN_LOGIN=1

DOCKER_URI='ssh://root@swarm1.dojtl.net'

USER_DIRS=

#HOSTNAME_TEMPLATE='{username}.amazingprogrammers.org'
HOSTNAME_TEMPLATE='{username}.code.jointheleague.org'
NODE_HOSTNAME_TEMPLATE='{nodename}.dojtl.net'

APP_DIR='/tmp/app/local-prod'
DATA_DIR='/tmp/app/local-prod'

KST_REPORTING_URL='http://codeserver:8000/telem'
KST_REPORT_INTERVAL=30
KST_REPORT_DIR='/tmp'

INTERNAL_CODESERVER_URL='http://codeserver:8000/'

GITHUB_ORG=https://github.com/League-Students

DO_NETWORK=10.124.0.0/20
DO_SIZE='s-4vcpu-8gb-amd'
DO_IMAGE='docker-20-04'
DO_REGIOIN='sfo3'
DO_NAMES='swarm{serial}.dojtl.net'
DO_PROJECT='e7c1cd82-5938-43f7-9554-98cf454113ca'
DO_TAG='codeserve'
