
DEVEL=
PRODUCTION=1
OAUTHLIB_INSECURE_TRANSPORT=1

# Dev-only: show a "Log in as admin" button on the login page that
# bypasses OAuth and logs in as the root admin user. Enabled here so a
# remote operator running `just dev-pl` can log in without OAuth.
DEV_ADMIN_LOGIN=1

DOCKER_URI='ssh://root@swarm1.dojtl.net'

USER_DIRS=

HOSTNAME_TEMPLATE='{username}.code.jointheleague.org'
NODE_HOSTNAME_TEMPLATE='{nodename}.dojtl.net'

# Use prod database directly
DATABASE_URI='postgresql://pguser:password@swarm1.dojtl.net:5432/codeserver'

APP_DIR='/tmp/app/local-prod'
DATA_DIR='/tmp/app/local-prod'

KST_REPORTING_URL='http://codeserver:8000/telem'
KST_REPORT_INTERVAL=30
KST_REPORT_DIR='/tmp'

INTERNAL_CODESERVER_URL='http://codeserver:8000/'

GITHUB_ORG=https://github.com/League-Students

# For creating new swarm hosts
DO_NETWORK=10.124.0.0/20
DO_SIZE='s-4vcpu-8gb-amd'
DO_IMAGE='docker-20-04'
DO_REGIOIN='sfo3'
DO_NAMES='swarm{serial}.dojtl.net'
DO_PROJECT='e7c1cd82-5938-43f7-9554-98cf454113ca'
DO_TAG='codeserve'
