# Shared non-secret config (from config/config.env)
USERID=1000
ADMIN_EMAILS=["eric.busboom@jointheleague.org", "admin@jointheleague.org", "it@jointheleague.org"]
INSTRUCTOR_EMAIL_REXEX=^[^@]+@jointheleague\.org$
STUDENT_EMAIL_REGEX=^[^@]+@students\.jointheleague\.org$
CODESERVER_PORT=80

# noVNC client URL path, appended after https://{host}/ for the desktop view.
# Direct Caddy /websockify route + auto-reconnect + max bandwidth reduction
# (quality=0 = lowest, compression=9 = highest) to survive class-start congestion.
# NOTE: values in this tree are UNQUOTED — the app's config-tree loader keeps
# surrounding quotes literally (unlike dotenv), so quotes would leak into the URL.
VNC_URL_PATH=vnc/vnc.html?autoconnect=true&reconnect=true&reconnect_delay=1000&resize=scale&quality=0&compression=9&path=websockify
# Variant without bandwidth caps (better image quality, more bytes):
#VNC_URL_PATH=vnc/vnc.html?autoconnect=true&reconnect=true&reconnect_delay=1000&resize=scale&path=websockify
# OLD: code-server /proxy/6080 hop, no reconnect — swap in to roll back.
#VNC_URL_PATH=proxy/6080/vnc_lite.html?path=proxy/6080/websockify&scale=true

SWARM_NODE_LABEL=code-host-user
SSH_WAIT_TIMEOUT=900
DO_CLOUD_INIT=swarm-node-init-v2.yaml

# Prod-specific non-secret config (from config/prod.env)
DEVEL=
PRODUCTION=1
OAUTHLIB_INSECURE_TRANSPORT=

# Dev-only admin-login bypass. MUST stay empty in production.
DEV_ADMIN_LOGIN=

DOCKER_URI=ssh://root@swarm1.dojtl.net

USER_DIRS=

HOSTNAME_TEMPLATE={username}.code.jointheleague.org
NODE_HOSTNAME_TEMPLATE={nodename}.dojtl.net

DATABASE_URI=postgresql://pguser:password@postgres:5432/codeserver

APP_DIR=/app
DATA_DIR=/app/data

KST_REPORTING_URL=http://codeserver:8000/telem
KST_REPORT_INTERVAL=30
KST_REPORT_DIR=/app/run

INTERNAL_CODESERVER_URL=http://codeserver:8000/

GITHUB_ORG=https://github.com/League-Students

DO_NETWORK=10.124.0.0/20
DO_SIZE=s-4vcpu-8gb-amd
NODE_TIERS=[{"name":"small","slug":"s-4vcpu-8gb-amd","capacity":6},{"name":"large","slug":"s-8vcpu-16gb-amd","capacity":14}]
DEFAULT_TIER=small
DEFAULT_CAPACITY=6
DO_IMAGE=docker-20-04
DO_REGIOIN=sfo3
DO_NAMES=swarm{serial}.dojtl.net
DO_PROJECT=e7c1cd82-5938-43f7-9554-98cf454113ca
DO_TAG=codeserve

# Keep code-server hosts off the swarm manager (swarm1); spread across workers.
PLACEMENT_CONSTRAINTS=node.role==worker

# SSH key file for embedding in Docker deployments via dotconfig load -e
ID_RSA_FILE=id_rsa

# Autoscaler config — shipped inert; operator must explicitly enable.
# AUTOSCALE_ENABLED=false  → autoscaler will not run until set to true.
# AUTOSCALE_DRY_RUN=true   → even when enabled, no provisioning/destruction occurs.
AUTOSCALE_ENABLED=false
AUTOSCALE_DRY_RUN=true
AUTOSCALE_HEADROOM=2
AUTOSCALE_ROSTER_FRACTION=0.8
AUTOSCALE_MAX_ADD_PER_CYCLE=2
AUTOSCALE_MAX_REMOVE_PER_CYCLE=1
AUTOSCALE_SCALEDOWN_COOLDOWN_MIN=30
AUTOSCALE_MIN_WORKER_NODES=1
AUTOSCALE_DEFAULT_CAPACITY=6
