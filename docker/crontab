PATH=/bin:/usr/bin:/usr/local/bin:/app
# The `/proc/1/fd/1 2>/proc/1/fd/2` sends both stdout and stderr to the
# stdout and stderr of the first process, which will output to the docker log

# Minutely
* * * * * curl -m 5 -X GET http://localhost:8000/cron/minutely >/proc/1/fd/1 2>/proc/1/fd/2

# */5 * * * * cspawnctl -d prod host reap  >/proc/1/fd/1 2>/proc/1/fd/2

# Autoscale worker nodes every 2 minutes.
# To activate:
#   Phase 0 (watch): uncomment the line below; keep AUTOSCALE_ENABLED=false (logs "disabled") to verify cron fires.
#   Phase 1 (dry-run): set AUTOSCALE_ENABLED=true in config; AUTOSCALE_DRY_RUN=true (default) — logs plans, no changes.
#   Phase 2 (live): after ≥1 week of dry-run review, set AUTOSCALE_DRY_RUN=false in config.
# WARNING: Uncommenting alone is NOT sufficient — you must also set AUTOSCALE_ENABLED=true in config.
# */2 * * * * cspawnctl -d prod node autoscale >/proc/1/fd/1 2>/proc/1/fd/2

# Hourly
0 * * * * curl -m 5 -X GET http://localhost:8000/cron/hourly >/proc/1/fd/1 2>/proc/1/fd/2

# Daily at midnight
0 0 * * * curl -m 5 -X GET http://localhost:8000/cron/daily >/proc/1/fd/1 2>/proc/1/fd/2
